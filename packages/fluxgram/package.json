{
  "name": "fluxgram",
  "version": "0.0.1",
  "description": "Durable, resumable Telegram bot flows for Bun/TypeScript",
  "keywords": [
    "bot",
    "bun",
    "durable",
    "flows",
    "grammy",
    "node",
    "telegram",
    "typescript",
    "workflow"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "testing"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./storage/mongo": {
      "bun": "./src/storage/mongo.ts",
      "types": "./dist/src/storage/mongo.d.ts",
      "import": "./dist/src/storage/mongo.js"
    },
    "./storage/sqlite": {
      "bun": "./src/storage/sqlite.ts",
      "types": "./dist/src/storage/sqlite.d.ts",
      "import": "./dist/src/storage/sqlite.js"
    },
    "./storage/redis": {
      "bun": "./src/storage/redis.ts",
      "types": "./dist/src/storage/redis.d.ts",
      "import": "./dist/src/storage/redis.js"
    },
    "./storage/postgres": {
      "bun": "./src/storage/postgres.ts",
      "types": "./dist/src/storage/postgres.d.ts",
      "import": "./dist/src/storage/postgres.js"
    },
    "./events/mongo": {
      "bun": "./src/events/mongo.ts",
      "types": "./dist/src/events/mongo.d.ts",
      "import": "./dist/src/events/mongo.js"
    },
    "./events/redis": {
      "bun": "./src/events/redis.ts",
      "types": "./dist/src/events/redis.d.ts",
      "import": "./dist/src/events/redis.js"
    },
    "./testing": {
      "bun": "./testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && bun build src/index.ts src/storage/mongo.ts src/storage/sqlite.ts src/storage/redis.ts src/storage/postgres.ts src/events/mongo.ts src/events/redis.ts testing/index.ts --outdir dist --root . --target node --format esm --packages external --splitting && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "lint": "oxlint src testing tests",
    "format": "oxfmt src testing tests",
    "format:check": "oxfmt --check src testing tests",
    "smoke:node": "node tests/node-smoke.mjs"
  },
  "dependencies": {
    "evlog": "^2.18.1",
    "grammy": "^1.43.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "mongodb": "^7.3.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "mongodb": "^7.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0 || ^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  }
}
